{{#> layout
  title='Pricing'
  url='/pricing.html'
  navbarAlwaysMurky=true
}}
  <div class="container-md text-center">
    <h1 class="mb-5 text-center">Pricing</h1>
    <p>Translations with Vocably are always free and unlimited. I am <a href="/about.html" class="link-secondary">working hard</a> to keep it this way.</p>

    <p>The <strong>Free Plan</strong> lets you save <strong>300 words</strong> in your study collection. When you have 300 words, you can only save one new word per day. All translations remain free and unlimited.</p>

    <p>With <strong>Premium</strong>, you can <strong>save unlimited words</strong> and get <strong>one more type of practice question</strong>:</p>
    <div style="text-align: center;"><video
      autoplay
      loop
      muted
      playsinline
      style="width: 184px; height: 400px"
    >
      <source src="assets/arrange-by-letters/mobile.mov" type="video/quicktime" />
      <source src="assets/arrange-by-letters/mobile.webm" type="video/webm" />
      The video is not supported by your browser.
    </video></div>
  </div>
  {{#> text-container }}
    <style>
      .features-table {
        th:not(:first-child), td:not(:first-child) {
          text-align: center;
        }

        td {
          vertical-align: middle;
        }

        tr:last-child td {
          border-bottom: none;
        }
      }

      .smaller-on-tiny-screens {
        font-size: 1.2rem;
      }

      @media (width < 450px) {
        .smaller-on-tiny-screens {
          font-size: 0.9rem;
        }
      }
    </style>

    <div style="overflow-x: auto;">
      <table class="table features-table">
        <tr style="vertical-align: bottom;">
          <th>Feature</th>
          <th>Free plan</th>
          <th>Premium</th>
        </tr>
        <tr>
          <td>Translate with Chrome/Safari extension</td>
          <td><i class="bi bi-check"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Translate in iOS/Android app</td>
          <td><i class="bi bi-check"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Translate with iOS Safari extension</td>
          <td><i class="bi bi-check"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Study all the saved flashcards in iOS/Android app</td>
          <td><i class="bi bi-check"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Study multiple languages</td>
          <td><i class="bi bi-check"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Save translations as flashcards</td>
          <td class="smaller-on-tiny-screens">
            <div><strong>First 300 cards</strong></div>
            <div>Unlimited</div>
            <div class="mt-3"><strong>Over 300 cards</strong></div>
            <div>1 card per day</div>
          </td>
          <td class="smaller-on-tiny-screens">Unlimited</td>
        </tr>
        <tr>
          <td>Extra question type</td>
          <td><i class="bi bi-x"></i></td>
          <td><i class="bi bi-check"></i></td>
        </tr>
        <tr>
          <td>Price</td>
          <td>&nbsp;</td>
          <td>
            <table style="margin: 0 auto; white-space: nowrap;" class="smaller-on-tiny-screens">
              <tr>
                <td class="text-end" style="min-width: 5rem;" data-monthly-price>
                  <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Loading...</span>
                  </div>
                </td>
                <td class="text-start" style="white-space: nowrap">/month</td>
              </tr>
              <tr>
                <td class="text-end" style="min-width: 5rem;" data-yearly-price>
                  <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Loading...</span>
                  </div>
                </td>
                <td class="text-start" style="">/year</td>
              </tr>
              <tr>
                <td class="text-end" style="min-width: 5rem;" data-lifetime-price>
                  <div class="spinner-border spinner-border-sm" role="status">
                    <span class="visually-hidden">Loading...</span>
                  </div>
                </td>
                <td class="text-start">&nbsp;lifetime</td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </div>
  {{/text-container}}
{{/layout}}

