<style>
  .search-form {
    --border-radius: 3rem;
    --height: 4rem;

    display: flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--bs-gray-500);
    border-radius: var(--border-radius);
    height: var(--height);
    background: #fff;
    transition: all 0.3s ease-in-out;
    box-shadow: 0 1px 12px 0 rgba(0, 0, 0, 0.5);

    &:has(:focus) {
      box-shadow: 0 1px 12px 0 var(--bs-primary);
    }

    .language-selector-wrapper {
      padding: 0 1rem;
      font-size: 60%;
      font-weight: bold;

      &:first-child {
        border-radius: var(--border-radius) 0 0 var(--border-radius);
        padding-left: 1.5rem;
      }

      &:has(:focus) {
        outline: none;
      }

      &:has(:focus-visible) {
        outline: auto;
        outline-color: Highlight;
        outline-color: -webkit-focus-ring-color;
      }

      position: relative;

      .label {
        text-transform: uppercase;
        width: 2rem;
        text-align: center;
        height: var(--height);
        line-height: var(--height);
      }

      select {
        position: absolute;
        left: 0;
        top: 0;
        right: 0;
        bottom: 0;
        opacity: 0;
        appearance: none;
      }

      &.delimiter {
        border-right: 1px solid var(--bs-gray-500);
        padding-left: 1rem;
        margin-right: 1rem;
      }
    }

    .text-input {
      flex: 1;
      border: none;
      font-weight: 300;
      outline: none;
      background: none;
      position: relative;
      height: var(--height);
      min-width: 0;
    }

    .submit-button {
      background: none;
      border: none;
      border-radius: 0 var(--border-radius) var(--border-radius) 0;
      height: var(--height);
      line-height: var(--height);
      padding: 0 1.5rem 0 1rem;
      text-align: center;
      color: inherit;

      &:focus-visible {
        outline: auto;
        outline-color: Highlight;
        outline-color: -webkit-focus-ring-color;
      }
    }

    @media (max-width: 600px) {
      gap: 0.1rem;

      .language-selector-wrapper {
        padding: 0 0.2rem;

        &.delimiter {
          padding-left: 0.4rem;
          margin-right: 0.4rem;
        }

        &:first-child {
          border-radius: var(--border-radius) 0 0 var(--border-radius);
          padding-left: 0.8rem;
        }
      }
    }
  }
</style>
{{#if sourceLanguage}}
  <script type='text/javascript'>
    window['searchFormSourceLanguage'] = '{{sourceLanguage}}';
  </script>
{{/if}}
<form class='search-form' id='searchForm' action='/search.html'>
  <div class='language-selector-wrapper'>
    <div class='label'></div>
    <select name='sourceLanguage'>
      {{#each htmlWebpackPlugin.options.environment.languages}}
        <option value='{{this.code}}'>{{this.label}}</option>
      {{/each}}
    </select>
  </div>
  <i class='bi bi-chevron-compact-right'></i>
  <div class='language-selector-wrapper delimiter'>
    <div class='label'></div>
    <select name='targetLanguage'>
      {{#each htmlWebpackPlugin.options.environment.languages}}
        <option value='{{this.code}}'>{{this.label}}</option>
      {{/each}}
    </select>
  </div>
  <input
    type='text'
    class='text-input'
    name='text'
    autocomplete='off'
    autocorrect='off'
    autocapitalize='none'
    value='{{query}}'
  />
  <input type='hidden' name='isReversed' value='false' />
  <button type='submit' class='submit-button'><i
      class='bi bi-search'
    ></i></button>
</form>
