<!doctype html>
<html lang="en" class="h-100">
  <head>
    <script>
      window.publicApiBaseUrl = '{{ htmlWebpackPlugin.options.environment.publicApiBaseUrl }}';
      window.paddleClientSideToken = '{{ htmlWebpackPlugin.options.environment.paddleClientSideToken }}';
      window.paddleMonthlyPriceId = '{{ htmlWebpackPlugin.options.environment.paddleMonthlyPriceId }}';
      window.paddleYearlyPriceId = '{{ htmlWebpackPlugin.options.environment.paddleYearlyPriceId }}';
      window.paddleLifetimePriceId = '{{ htmlWebpackPlugin.options.environment.paddleLifetimePriceId }}';
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600&display=swap" rel="stylesheet">
    <title>Vocably{{#if title}} - {{title}}{{/if}}</title>
    <meta name="description" content="{{#if metaDescription}}{{metaDescription}}{{else}}Combination of contextual dictionary and flashcards. Select → Translate → Save → Learn. Supports Chrome, Safari, iOS, Android.{{/if}}" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Vocably{{#if title}} - {{title}}{{/if}}" />
    <meta property="og:description" content="{{#if ogDescription}}{{ogDescription}}{{else}}Combination of contextual dictionary and flashcards. Select → Translate → Save → Learn.{{/if}}" />
    <meta property="og:url" content="{{htmlWebpackPlugin.options.environment.baseUrl}}{{url}}" />
    <meta property="og:image" content="{{htmlWebpackPlugin.options.environment.baseUrl}}/assets/og-image.png" />
    <link rel="canonical" href="{{htmlWebpackPlugin.options.canonicalHref}}" />
    <meta name="apple-itunes-app" content="app-id=1641258757" />
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-element-bundle.min.js"></script>
    <base href="/" />
    <style>
      .show-android,
      .hide-android,
      .show-ios,
      .hide-ios,
      .hide-chrome,
      .hide-safari,
      .show-chrome,
      .show-safari,
      .show-any,
      .show-other {
        visibility: hidden;
      }
    </style>
  </head>
  <body id="page-top" class="d-flex flex-column min-vh-100">
    {{#unless disableAnalytics}}
      <script defer src="https://cloud.umami.is/script.js" data-website-id="{{ htmlWebpackPlugin.options.environment.umamiWebsiteId }}"></script>
    {{/unless}}
    {{#unless hideNavBar}}
      <style>
        .navbar-bg {
          background: linear-gradient(180deg, rgba(255, 255, 255, 1) 0%, rgba(255, 255, 255, 0.2) 100%);
          backdrop-filter: blur(10px);
        }

        @media (width >= 1000px) {
          .navbar-bg:not(.navbar-bg-always) {
            background: none;
            backdrop-filter: none;
          }
        }

        .sticky-menu {
          position: sticky;
          top: 0;
          z-index: 1020;
        }

        .navbar-home-link {
          flex: 0 1 auto;
          align-self: self-start;
          margin-top: 4px;
        }

        .nav-logo {
          height: 1.6rem;
        }
      </style>
      <nav class="navbar navbar-expand-lg navbar-light sticky-menu navbar-bg sticky-top mb-4 mb-lg-0 px-4{{#if navbarAlwaysMurky}} navbar-bg-always{{/if}}{{#if navbarClass}} {{ navbarClass }}{{/if}}" style="">
        <div class="{{#if navbarContainerClass}}{{ navbarContainerClass }}{{else}}container-fluid{{/if}} p-0">
          <a class="navbar-home-link" href="/">
            <img
              src="assets/logo.svg"
              alt="Vocably"
              class="nav-logo"
            />
          </a>
          {{#unless noCta}}
            <div class="d-flex flex-column get-button">
              <a
                href='https://chrome.google.com/webstore/detail/vocably/baocigmmhhdemijfjnjdidbkfgpgogmb'
                class='show-chrome btn btn-primary btn-sm rounded-pill px-5 text-sm'
                data-umami-event='CTA Click'
                data-umami-event-label='Chrome Extension'
              >Get started</a>
              <a
                href='https://apps.apple.com/app/id6464076425'
                class='show-safari btn btn-primary btn-sm rounded-pill px-5 text-sm'
                data-umami-event='CTA Click'
                data-umami-event-label='Safari Extension'
              >Get started</a>
              <a
                href='https://play.google.com/store/apps/details?id=com.vocablypro'
                class='show-android btn btn-primary btn-sm rounded-pill px-5 text-sm'
                data-umami-event='CTA Click'
                data-umami-event-label='Android app'
              >Get started</a>
              <a
                href='https://apps.apple.com/app/vocably-pro-language-cards/id1641258757'
                class='show-ios btn btn-primary btn-sm rounded-pill px-5 text-sm'
                data-umami-event='CTA Click'
                data-umami-event-label='iOS app'
              >Get started</a>
            </div>
          {{/unless}}
        </div>
      </nav>
    {{/unless}}
    <main class="flex-shrink-0">
      {{> @partial-block }}
    </main>

    <footer class="bg-gray mt-auto text-white-50" style="font-size: 1rem;">
      <div class="container-md py-5">
        <div class="mb-4">
          <a href="/"><img src="/assets/logo-dark.svg" alt="Vocably" style="height: 1.3em;opacity: 0.5"/></a>
        </div>
        <div class="row g-3 justify-content-start justify-content-lg-center">
          <div class="col-6 col-md-4 mb-4 mb-lg-0">
            <ul class="list-unstyled mb-0">
              {{#unless hidePricing}}<li class="mb-2"><a href="/pricing.html">Pricing</a></li>{{/unless}}
              <li class="mb-2"><a href="https://chrome.google.com/webstore/detail/vocably/baocigmmhhdemijfjnjdidbkfgpgogmb" target="_blank"
                data-umami-event='Footer CTA Click'
                data-umami-event-label='Chrome Extension'
              >Chrome Extension</a></li>
              <li class="mb-2"><a href="https://apps.apple.com/app/id6464076425" target="_blank"
                data-umami-event='Footer CTA Click'
                data-umami-event-label='Desktoop Safari Extension'>Desktop Safari Extension</a></li>
              <li class="mb-2"><a href="/ios-safari-extension.html" target="_blank"
                data-umami-event='Footer CTA Click'
                data-umami-event-label='iOS Safari Extension'
              >iOS Safari Extension</a></li>
              <li class="mb-2"><a href="https://play.google.com/store/apps/details?id=com.vocablypro" target="_blank"
                data-umami-event='Footer CTA Click'
                data-umami-event-label='Android App'
              >Android App</a></li>
              <li class="mb-2"><a href="https://apps.apple.com/app/vocably-pro-language-cards/id1641258757" target="_blank"
                data-umami-event='Footer CTA Click'
                data-umami-event-label='iOS App'
              >iOS App</a></li>
            </ul>
          </div>
          <div class="col-6 col-md-4 mb-4 mb-md-0">
            <ul class="list-unstyled mb-0">
              <li class="mb-2"><a href="/about.html">About</a></li>
              <li class="mb-2"><a href="/search.html">Online Dictionary</a></li>
              <li class="mb-2"><a href="/grammar.html">Online Grammar Corrector</a></li>
              <li class="mb-2"><a href="/privacy-policy.html">Privacy Policy</a></li>
              <li class="mb-2"><a href="/terms-and-conditions.html">Terms and Conditions</a></li>
            </ul>
          </div>
          <div class="col-12 col-md-4 mb-4 mb-md-0">
            <div class="text-uppercase fw-bold mb-2">Let's connect</div>
            <div class="mb-2">Have questions or suggestions? Feel free to message me through these channels. I reply to everyone.</div>
            <div class="mb-2" style="font-size: 1.4rem;">
              <a
                href="https://t.me/vocably"
                class="text-decoration-none link-secondary me-1"
                target="_blank"
                aria-label="Telegram"
              >
                <i class="bi bi-telegram"></i>
              </a>
              <a
                href="https://discord.gg/9aRwbJ3qeh"
                class="text-decoration-none link-secondary me-1"
                target="_blank"
                aria-label="Discord"
              >
                <i class="bi bi-discord"></i>
              </a>
              <a
                href="https://github.com/vocably/language-learning-tool"
                class="text-decoration-none link-secondary"
                target="_blank"
                aria-label="GitHub"
              >
                <i class="bi bi-github"></i>
              </a>
            </div>
            <a href="mailto:d@vocably.pro" class="text-nowrap"><i class="bi bi-envelope align-middle me-1"></i>d@vocably.pro</a>
          </div>
        </div>
      </div>
      <div class="bg-dark py-4 text-center">
        <div class="container-md">
          &copy; Vocably BV — made with  <i class="bi bi-heart-fill text-danger" data-bs-toggle="tooltip" data-bs-title="You are a curious person and that's why I like you."></i> in Amsterdam</li>
        </div>
      </div>
    </footer>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
    ></script>
  </body>
</html>
