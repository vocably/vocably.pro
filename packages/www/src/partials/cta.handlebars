<a
  href='https://chrome.google.com/webstore/detail/vocably/baocigmmhhdemijfjnjdidbkfgpgogmb'
  class='show-chrome cta-button d-block w-100'
  data-umami-event='{{eventPrefix}}CTA Click'
  data-umami-event-label='Chrome Extension'
><img
    aria-hidden='true'
    src='assets/chrome.svg'
    style='height: 1em; margin-right: 0.5rem;vertical-align: sub;'
  />Install Chrome Extension</a>
<a
  href='https://apps.apple.com/app/id6464076425'
  class='show-safari cta-button d-block w-100'
  data-umami-event='{{eventPrefix}}CTA Click'
  data-umami-event-label='Safari Extension'
>Install Safari Extension</a>
<a
  href='https://play.google.com/store/apps/details?id=com.vocablypro'
  class='show-android cta-button d-block w-100'
  data-umami-event='{{eventPrefix}}CTA Click'
  data-umami-event-label='Android App'
>Install Android App</a>
<a
  href='https://apps.apple.com/app/vocably-pro-language-cards/id1641258757'
  class='show-ios cta-button d-block w-100'
  data-umami-event='{{eventPrefix}}CTA Click'
  data-umami-event-label='iOS App'
>Install iOS App</a>
<div
  class='mt-2 d-flex flex-direction-row align-items-center justify-content-center gap-2'
>
  <span class='show-any' style='font-size: 85%;'>Also supports</span>
  <span class='show-other'>Supports</span>
  <ul
    class='cta-platforms list-unstyled d-inline-flex align-items-start justify-content-center gap-2 align-middle m-0'
  >
    <li class='hide-chrome'>
      <a
        href='https://chrome.google.com/webstore/detail/vocably/baocigmmhhdemijfjnjdidbkfgpgogmb'
        target='_blank'
        data-umami-event='{{eventPrefix}}CTA Click'
        data-umami-event-label='Chrome Extension'
      >
        <img src='assets/chrome.svg' alt='Chrome Logo' />
        <span>Chrome</span>
      </a>
    </li>
    <li class='hide-ios' style='margin-top: -2px'>
      <a
        href='https://apps.apple.com/app/vocably-pro-language-cards/id1641258757'
        target='_blank'
        data-umami-event='{{eventPrefix}}CTA Click'
        data-umami-event-label='iOS App'
      >
        <img src='assets/apple.svg' alt='Apple Logo' />
        <span>iOS</span>
      </a>
    </li>
    <li class='hide-android'>
      <a
        href='https://play.google.com/store/apps/details?id=com.vocablypro'
        class='android'
        target='_blank'
        data-umami-event='{{eventPrefix}}CTA Click'
        data-umami-event-label='Android App'
      >
        <img src='assets/android.svg' alt='Android Logo' />
        <span>Android</span>
      </a>
    </li>
    <li class='hide-safari'>
      <a
        href='https://apps.apple.com/app/id6464076425'
        target='_blank'
        data-umami-event='{{eventPrefix}}CTA Click'
        data-umami-event-label='Safari Extension'
      >
        <img src='assets/safari.svg' alt='Safari Logo' />
        <span>Safari</span>
      </a>
    </li>
  </ul>
</div>
