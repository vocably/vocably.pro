{
  "name": "@vocably/www",
  "version": "0.0.0",
  "private": true,
  "description": "Extension popup",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "compileSeo": "tsc --project seo/tsconfig.json",
    "watchSeo": "tsc --watch --project seo/tsconfig.json",
    "prebuild": "npx rimraf dist && npm run compileSeo",
    "build": "webpack --env production",
    "postbuild": "npx rimraf ./seo/cache && npx vite-node ./seo/build.mts",
    "serve": "webpack serve --env development --open",
    "watch": "webpack --watch --env development",
    "start": "npm-run-all --parallel watchSeo watch serve",
    "test": "echo '@vocably/www has no tests.'",
    "www": "npm start"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sneas/green-blocker.git"
  },
  "devDependencies": {
    "vite-node": "^6.0.0"
  }
}
