const allowedSourceLanguages: GoogleLanguage[] = [
  'it',
  'ar',
  'no',
  'en',
  'es',
  'da',
  'ru',
  'pl',
  'en-GB',
  'nl',
  'zh',
  'pt',
  'sv',
  'ja',
  'he',
  'el',
  'fi',
  'ko',
  'fr',
  'tr',
  'th',
  'de',
];

let rows = [];

for (const [sourceLanguage, option] of Object.entries(
  predefinedPartsOfSpeech
)) {
  if (!allowedSourceLanguages.includes(sourceLanguage as GoogleLanguage)) {
    continue;
  }
  for (const { headword: source, partOfSpeech } of option) {
    for (const translationLanguage of Object.keys(languageList)) {
      if (sourceLanguage === translationLanguage) {
        continue;
      }

      const fileName = getAnalyseCacheFileName({
        sourceLanguage: sourceLanguage as GoogleLanguage,
        partOfSpeech,
        source,
      });

      const filePath = `./../../vocably-languages/${fileName}`;

      const unitOfSpeech = JSON.parse(readFileSync(filePath, 'utf8'));

      rows.push(
        getGeminiTranslationBatchItem({
          sourceLanguage: sourceLanguage as GoogleLanguage,
          partOfSpeech,
          definitions: unitOfSpeech.definitions,
          number: unitOfSpeech.number,
          source,
          targetLanguage: translationLanguage as GoogleLanguage,
        })
      );
    }
  }
}

console.log('Records count', rows.length);

writeFileSync(
  `./data/batches/predefined-translations-jobs.jsonl`,
  rows.map((r) => JSON.stringify(r)).join('\n')
);
