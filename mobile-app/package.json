{
  "name": "VocablyPro",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "npm run setup-safari-extension-dev && react-native start --reset-cache --verbose",
    "test": "jest",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "reset-ios": "rm -rf ios/build ios/Pods && npx pod-install",
    "reset-android": "rm -rf android/.gradle android/build android/app/build",
    "deploy-ios-dev": "SENTRY_DISABLE_AUTO_UPLOAD=true npm run setup-safari-extension-dev && (cd ios && fastlane ios build && fastlane ios beta)",
    "deploy-ios-prod": "npm run setup-safari-extension-prod && (npm run setup-prod-env && cd ios && fastlane ios build && npm run setup-dev-env && fastlane ios beta) && npm run setup-safari-extension-dev",
    "deploy-android": "(npm run setup-prod-env && cd android && fastlane android beta && npm run setup-dev-env)",
    "deploy-dev": "npm run deploy-android && npm run deploy-ios-dev",
    "list-devices": "xcrun simctl list devices",
    "setup-prod-env": "cp .env.prod .env",
    "setup-dev-env": "cp .env.dev .env",
    "copy-ios-extension": "cp -a ../packages/ios-extension/dist/. ios/Vocably\\ for\\ Safari/Resources",
    "setup-safari-extension-dev": "npm run build-dev --prefix ../packages/ios-extension && npm run copy-ios-extension",
    "setup-safari-extension-prod": "npm run build-prod --prefix ../packages/ios-extension && npm run copy-ios-extension",
    "postinstall": "patch-package",
    "premobile-app": "sed -i '' 's/^ANALYTICS_DISABLED.*/ANALYTICS_DISABLED=\"true\"/' .env",
    "mobile-app": "npm start"
  },
  "dependencies": {
    "@aws-amplify/react-native": "^1.3.3",
    "@aws-amplify/rtn-push-notification": "^1.3.1",
    "@aws-amplify/rtn-web-browser": "^1.4.0",
    "@aws-crypto/sha256-js": "^5.2.0",
    "@miblanchard/react-native-slider": "^2.6.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-clipboard/clipboard": "^1.16.2",
    "@react-native-community/datetimepicker": "^8.4.5",
    "@react-native-community/netinfo": "^11.3.3",
    "@react-native-masked-view/masked-view": "0.3.1",
    "@react-navigation/bottom-tabs": "^7.4.8",
    "@react-navigation/drawer": "^7.5.9",
    "@react-navigation/native": "^7.1.18",
    "@react-navigation/stack": "^7.4.9",
    "@sentry/react-native": "7.13.0",
    "@shopify/flash-list": "2.3.1",
    "aws-amplify": "^6.13.4",
    "events": "^3.3.0",
    "i18next": "^26.3.0",
    "intl-pluralrules": "^2.0.1",
    "posthog-react-native": "^3.3.6",
    "react": "19.2.3",
    "react-i18next": "^17.0.8",
    "react-native": "0.85.3",
    "react-native-blob-util": "^0.24.9",
    "react-native-device-info": "^13.1.0",
    "react-native-gesture-handler": "^2.31.2",
    "react-native-get-random-values": "1.11.0",
    "react-native-keyboard-controller": "^1.21.8",
    "react-native-linear-gradient": "2.8.3",
    "react-native-localize": "^3.4.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "4.3.1",
    "react-native-nitro-modules": "0.35.7",
    "react-native-paper": "^5.15.2",
    "react-native-purchases": "^9.11.2",
    "react-native-purchases-ui": "^9.11.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "^5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-shared-group-preferences": "^1.1.24",
    "react-native-sortables": "^1.9.2",
    "react-native-sound": "^0.13.0",
    "react-native-svg": "^15.15.5",
    "react-native-swipe-list-view": "3.2.9",
    "react-native-swiper": "^1.6.0",
    "react-native-vector-icons": "10.0.3",
    "react-native-version-number": "^0.3.6",
    "react-native-worklets": "0.8.3",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.3",
    "@react-native-community/cli-platform-android": "20.1.3",
    "@react-native-community/cli-platform-ios": "20.1.3",
    "@react-native/babel-preset": "0.85.3",
    "@react-native/eslint-config": "0.85.3",
    "@react-native/jest-preset": "0.85.3",
    "@react-native/metro-config": "0.85.3",
    "@react-native/typescript-config": "0.85.3",
    "@tsconfig/react-native": "^3.0.0",
    "@types/jest": "^29.5.13",
    "@types/metro-config": "^0.76.3",
    "@types/react": "^19.1.1",
    "@types/react-native-share-menu": "^5.0.5",
    "@types/react-native-vector-icons": "^6.4.12",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^5.37.0",
    "@typescript-eslint/parser": "^5.37.0",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "lodash-es": "^4.17.21",
    "patch-package": "^8.0.0",
    "react-native-dotenv": "^3.4.8",
    "react-native-share-menu": "^6.0.0",
    "react-test-renderer": "19.2.3",
    "typescript": "5.0.4"
  },
  "jest": {
    "preset": "react-native",
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "moduleNameMapper": {
      "^lodash-es$": "lodash"
    }
  },
  "engines": {
    "node": ">=18"
  }
}
